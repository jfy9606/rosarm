<launch>
    <!-- 启动YOLO检测节点 -->
    <node name="yolo_detector_visual_servo" pkg="stereo_vision" type="yolo_detector.py" output="screen">
        <param name="model" value="yolov8n.pt" />
        <param name="conf" value="0.25" />
        <param name="iou_threshold" value="0.45" />
        <param name="same_class_only" value="false" />
        <param name="image_topic" value="/stereo_camera/image_merged" />
    </node>
    
    <!-- 启动视觉伺服控制节点 -->
    <node name="visual_servo_controller" pkg="arm_trajectory" type="visual_servo_controller.py" output="screen">
        <param name="distance_threshold" value="0.05" />
        <param name="approach_speed" value="0.01" />
        <param name="z_offset" value="0.05" />
    </node>
    
    <!-- 启动轨迹规划和运动执行节点 -->
    <node name="trajectory_bridge" pkg="arm_trajectory" type="trajectory_bridge_node.py" output="screen">
        <param name="execution_speed" value="1.0" />
        <param name="trajectory_sampling_rate" value="50" />
    </node>
    
    <!-- 启动路径规划节点 -->
    <node name="path_planner" pkg="arm_trajectory" type="path_planner.py" output="screen">
        <param name="optimization_max_iter" value="100" />
        <param name="optimization_particles" value="30" />
        <param name="visualization_enabled" value="true" />
    </node>
    
    <!-- 启动机械臂控制节点 -->
    <include file="$(find arm_gui)/launch/arm_gui.launch">
        <arg name="with_stereo_vision" value="true" />
        <arg name="with_yolo_controller" value="false" />
        <arg name="with_path_planner" value="false" />
        <arg name="with_trajectory_planner" value="false" />
        <arg name="start_rviz" value="false" />
    </include>
    
    <!-- 打印使用说明 -->
    <node name="usage_info" pkg="rostopic" type="rostopic" args="pub -1 /arm_status std_msgs/String '使用方法：
    1. 发送 servo [物体ID] 命令启动视觉伺服控制
    2. 发送 move_to x y z 命令移动到特定坐标位置
    3. 发送 stop 停止控制
    4. 发送 vacuum on/off 控制吸盘'" />
</launch> 