<?xml version="1.0"?>
<launch>
    <!-- 参数设置 -->
    <arg name="servo_port" default="/dev/ttyUSB0" doc="舵机控制串口（波特率1000000）" />
    <arg name="camera_index" default="0" doc="摄像头索引" />
    <arg name="yolo_enabled" default="true" doc="是否启用YOLO目标检测" />
    <arg name="yolo_model_path" default="" doc="自定义YOLOv8模型路径" />
    <arg name="yolo_confidence" default="0.5" doc="YOLO检测置信度阈值" />
    <arg name="use_depth" default="true" doc="是否启用深度图计算" />
    <arg name="start_rviz" default="false" doc="是否启动RViz可视化" />
    
    <!-- 启动独立的视觉系统 -->
    <include file="$(find vision)/launch/vision.launch">
        <arg name="stereo_cam_device" value="/dev/video$(arg camera_index)" />
        <arg name="yolo_model_path" value="$(arg yolo_model_path)" />
        <arg name="enable_detection" value="$(arg yolo_enabled)" />
        <arg name="start_rviz" value="false" /> <!-- 避免启动多个RViz -->
    </include>
    
    <!-- 启动独立的机械臂控制系统 -->
    <include file="$(find arm_trajectory)/launch/arm_control.launch">
        <arg name="servo_port" value="$(arg servo_port)" />
        <arg name="start_rviz" value="false" /> <!-- 避免启动多个RViz -->
    </include>
    
    <!-- 启动视觉伺服桥接节点 - 用于将视觉信息转换为机械臂控制命令 -->
    <node name="visual_servo_bridge" pkg="arm_trajectory" type="visual_servo_bridge.py" output="screen">
        <param name="detection_topic" value="/detections/poses" />
        <param name="target_pose_topic" value="/trajectory/target_pose" />
    </node>
    
    <!-- 可选启动RViz -->
    <group if="$(arg start_rviz)">
        <node name="rviz" pkg="rviz" type="rviz" args="-d $(find arm_trajectory)/rviz/visual_servo.rviz" />
    </group>
</launch> 