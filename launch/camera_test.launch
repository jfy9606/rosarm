<?xml version="1.0"?>
<launch>
  <!-- 参数设置 -->
  <arg name="left_device" default="/dev/video0" doc="左相机设备" />
  <arg name="right_device" default="/dev/video1" doc="右相机设备" />
  <arg name="width" default="640" doc="图像宽度" />
  <arg name="height" default="480" doc="图像高度" />
  <arg name="fps" default="30" doc="帧率" />

  <!-- 相机测试节点 -->
  <node name="left_cam" pkg="usb_cam" type="usb_cam_node" output="screen">
    <param name="video_device" value="$(arg left_device)" />
    <param name="image_width" value="$(arg width)" />
    <param name="image_height" value="$(arg height)" />
    <param name="pixel_format" value="yuyv" />
    <param name="framerate" value="$(arg fps)" />
    <param name="camera_frame_id" value="left_camera" />
    <remap from="/usb_cam/image_raw" to="/left_cam/image_raw" />
  </node>

  <node name="right_cam" pkg="usb_cam" type="usb_cam_node" output="screen">
    <param name="video_device" value="$(arg right_device)" />
    <param name="image_width" value="$(arg width)" />
    <param name="image_height" value="$(arg height)" />
    <param name="pixel_format" value="yuyv" />
    <param name="framerate" value="$(arg fps)" />
    <param name="camera_frame_id" value="right_camera" />
    <remap from="/usb_cam/image_raw" to="/right_cam/image_raw" />
  </node>

  <!-- 图像查看器 -->
  <node name="left_view" pkg="image_view" type="image_view" output="screen">
    <remap from="image" to="/left_cam/image_raw" />
    <param name="autosize" value="true" />
    <param name="window_name" value="左摄像头" />
  </node>

  <node name="right_view" pkg="image_view" type="image_view" output="screen">
    <remap from="image" to="/right_cam/image_raw" />
    <param name="autosize" value="true" />
    <param name="window_name" value="右摄像头" />
  </node>
</launch> 