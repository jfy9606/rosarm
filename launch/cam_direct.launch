<?xml version="1.0"?>
<launch>
  <!-- 摄像头测试启动文件 -->
  <!-- 这个文件用于直接测试摄像头，不依赖于其他组件 -->

  <!-- 直接使用USB摄像头驱动 -->
  <node name="usb_cam" pkg="usb_cam" type="usb_cam_node" output="screen" respawn="true">
    <param name="video_device" value="/dev/video0" />
    <!-- 使用摄像头支持的最佳分辨率 1280x480@30fps -->
    <param name="image_width" value="1280" />
    <param name="image_height" value="480" />
    <param name="pixel_format" value="mjpeg" />
    <param name="io_method" value="mmap" /> <!-- 使用mmap方法 -->
    <param name="camera_frame_id" value="camera_link" />
    <param name="framerate" value="30" />
    <param name="camera_name" value="stereo_camera" />
    <param name="brightness" value="128" /> <!-- 中等亮度 -->
    <param name="contrast" value="128" /> <!-- 中等对比度 -->
    <param name="autofocus" value="false" /> <!-- 关闭自动对焦，解决焦距问题 -->
    <param name="focus" value="0" /> <!-- 固定对焦位置 -->
  </node>

  <!-- 双目图像分割器 -->
  <node name="stereo_splitter" pkg="stereo_vision" type="stereo_splitter.py" output="screen" respawn="true">
    <param name="crop_vertical" value="0" />
    <param name="log_level" value="1" /> <!-- 标准日志级别 -->
    <param name="save_test_image" value="true" />
  </node>

  <!-- 添加图像处理节点 -->
  <node name="image_proc" pkg="image_proc" type="image_proc" output="screen" ns="usb_cam">
    <param name="approximate_sync" value="true" />
  </node>

  <!-- 添加摄像头坐标转换 -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="camera_link_broadcaster"
        args="0 0 0.5 0 0 0 world camera_link" />

  <!-- 左右眼坐标系转换 - 基于60mm基线 -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="left_camera_link_broadcaster"
        args="-0.03 0 0 0 0 0 camera_link left_camera_link" />
  <node pkg="tf2_ros" type="static_transform_publisher" name="right_camera_link_broadcaster"
        args="0.03 0 0 0 0 0 camera_link right_camera_link" />

  <!-- 启动RViz用于可视化 -->
  <node name="rviz" pkg="rviz" type="rviz" args="-d $(find stereo_vision)/rviz/stereo_vision.rviz" />

  <!-- 注意: 如果RViz配置文件不存在，请先手动启动RViz并保存配置 -->

</launch> 